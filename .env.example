# ============================================
# CDK Gateway Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/cdk_gateway

# Admin Authentication
ADMIN_PASSWORD=your_admin_password_here
JWT_SECRET=your_jwt_secret_here_change_this

# CLIProxyAPIPlus (OpenAI-compatible upstream)
CLIPROXY_BASE_URL=http://localhost:8080
CLIPROXY_API_KEY=your_cliproxy_api_key_here

# claude-code-proxy (Anthropic-compatible upstream)
CLAUDE_PROXY_BASE_URL=http://localhost:8081
CLAUDE_PROXY_API_KEY=your_claude_proxy_api_key_here

# Optional: Default pricing (per million tokens, in USD)
DEFAULT_INPUT_PRICE=3.0
DEFAULT_OUTPUT_PRICE=15.0
